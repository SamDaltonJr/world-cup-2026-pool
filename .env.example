# Copy this file to ".env" and fill in your Supabase project values.
# Project Settings -> API in the Supabase dashboard.
#
# NOTE: The anon key is PUBLIC by design in a client-side app. It ends up in
# the built JS bundle. Access is controlled by Row-Level Security (see
# supabase/schema.sql), not by hiding this key.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Commissioner passcode for the admin tab. Change this before sharing!
# (Client-side only — fine for a friendly pool, not real security.)
VITE_ADMIN_CODE=commish2026
